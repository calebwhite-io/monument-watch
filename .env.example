# Copy this file to `.env` and fill in what you have. Every key here is FREE.
# The tool runs without any keys, but two sources will stay disabled until you add theirs.

# congress.gov API key — free, instant signup at https://api.congress.gov/sign-up/
# Enables the `congress` source (bills mentioning the monuments / Antiquities Act).
CONGRESS_API_KEY=

# regulations.gov API key — free signup at https://open.gsa.gov/api/regulationsgov/
# (click "Request an API key"). Enables the `regulations_gov` source (open comment periods).
REGS_API_KEY=

# CourtListener API token — OPTIONAL. The litigation source works without it at a
# lower rate limit. Free account at https://www.courtlistener.com/sign-in/ then
# https://www.courtlistener.com/help/api/rest/ for the token.
COURTLISTENER_API_TOKEN=

# Email used in the User-Agent so agencies can contact you about this scraper's
# traffic. Polite scrapers identify themselves. Any address you actually read.
CONTACT_EMAIL=
